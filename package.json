{
  "name": "hero-code",
  "displayName": "Hero Code",
  "description": "A VS Code extension.",
  "version": "0.0.1",
  "publisher": "tult",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hero-code-sessions",
          "title": "Claude Sessions",
          "icon": "media/claude.svg"
        }
      ]
    },
    "views": {
      "hero-code-sessions": [
        {
          "id": "hero-code.sessions",
          "name": "Sessions",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "vscode:prepublish": "npm run package",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.90.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.x",
    "esbuild": "^0.24.0",
    "eslint": "^9.x",
    "typescript": "^5.x",
    "typescript-eslint": "^8.x"
  }
}
