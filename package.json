{
  "name": "hero-code",
  "displayName": "Hero Code",
  "description": "Manage multiple Claude Code sessions at once — realtime status, one-click new session, pin, rename & mark done, all from a VS Code sidebar.",
  "version": "0.0.14",
  "publisher": "tule",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tult98/hero-code.git"
  },
  "keywords": [
    "claude",
    "claude code",
    "ai",
    "terminal",
    "assistant"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "Hero Code",
      "properties": {
        "heroCode.newSessionMode": {
          "type": "string",
          "enum": [
            "terminal",
            "chat"
          ],
          "enumDescriptions": [
            "Open new and resumed sessions in an integrated terminal running the Claude CLI (default).",
            "Open new and idle sessions in an in-editor GUI chat window powered by the Claude Agent SDK. Sessions already running live in a terminal still open in a terminal."
          ],
          "default": "terminal",
          "description": "How to open Claude sessions: an integrated terminal, or an in-editor GUI chat window."
        },
        "heroCode.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Show session debug info (launch id, live id, PID) in a hover tooltip on each session row."
        },
        "heroCode.claudePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the `claude` executable that the GUI chat window (Claude Agent SDK) should drive. Leave empty to auto-detect from common install locations and your shell's PATH."
        },
        "heroCode.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default model for new GUI chat sessions, set via the `/model` panel's \"Set as default\". A model id or alias (e.g. `opus`, `sonnet`, `claude-opus-4-8`). Leave empty to use the CLI's own default."
        },
        "heroCode.defaultEffort": {
          "type": "string",
          "enum": [
            "",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "default": "",
          "description": "Default reasoning effort for new GUI chat sessions, set via the `/model` panel. Leave empty to use the model's default."
        }
      }
    },
    "commands": [
      {
        "command": "hero-code.mentionInSession",
        "title": "Hero Code: Send Selection to Claude Session"
      }
    ],
    "keybindings": [
      {
        "command": "hero-code.mentionInSession",
        "key": "ctrl+alt+k",
        "mac": "alt+cmd+k",
        "when": "editorTextFocus"
      },
      {
        "command": "workbench.view.extension.hero-code-sessions",
        "key": "ctrl+shift+c",
        "mac": "shift+cmd+c"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hero-code-sessions",
          "title": "Claude Sessions",
          "icon": "media/claude.svg"
        },
        {
          "id": "hero-code-chat",
          "title": "Claude Chat",
          "icon": "media/claude.svg"
        }
      ]
    },
    "views": {
      "hero-code-sessions": [
        {
          "id": "hero-code.sessions",
          "name": "Sessions",
          "type": "webview"
        }
      ],
      "hero-code-chat": [
        {
          "id": "hero-code.chat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "vscode:prepublish": "npm run package",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/webview/tsconfig.json",
    "lint": "eslint src",
    "release": "vsce publish"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.209",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^20.x",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.90.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.x",
    "esbuild": "^0.24.0",
    "eslint": "^9.x",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.x",
    "typescript-eslint": "^8.x"
  }
}
