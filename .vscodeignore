.serena/**
media/claude.webp
src/**
node_modules/**
# The Claude Agent SDK is loaded at runtime (external, not bundled), so it and
# its platform-specific CLI binary must ship in the .vsix. npm installs only the
# current platform's optional binary — a cross-platform release needs a
# per-platform `vsce package --target` build.
!node_modules/@anthropic-ai/**
.gitignore
.yarnrc
esbuild.js
eslint.config.mjs
tsconfig.json
**/*.map
**/*.ts
**/.eslintrc.json
